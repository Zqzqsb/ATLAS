# LUCID Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Port Configuration (Optional)
# ============================================
# Default ports use 19xxx series to avoid conflicts
# Uncomment and modify if you need different ports

# LUCID_FRONTEND_PORT=19000
# LUCID_BACKEND_PORT=19001
# LUCID_MARIADB_PORT=19010

# ============================================
# LLM API Configuration (Required)
# ============================================
# Configure your LLM provider API key
# Supported providers: OpenAI, Hunyuan

# OpenAI API Key
# LLM_API_KEY=sk-your-openai-api-key-here

# Hunyuan API Key (alternative)
# HUNYUAN_API_KEY=your-hunyuan-key
# HUNYUAN_SECRET_KEY=your-hunyuan-secret

# Default LLM model to use
# LLM_DEFAULT_MODEL=deepseek_v3

# ============================================
# Database Configuration (Optional)
# ============================================
# Override default database credentials if needed

# MARIADB_ROOT_PASSWORD=lucid_root_2024
# MARIADB_USER=lucid
# MARIADB_PASSWORD=lucid2024
# MARIADB_DATABASE=lucid

# ============================================
# Application Configuration (Optional)
# ============================================

# Server mode: debug | release
# SERVER_MODE=release

# Enable/disable features
# ENABLE_RICH_CONTEXT=true
# MAX_REACT_ITERATIONS=5

# ============================================
# Development Options (Optional)
# ============================================

# Enable debug logging
# DEBUG=true

# CORS settings for development
# CORS_ALLOW_ALL=true
