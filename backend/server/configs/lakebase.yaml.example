# Lake-Base Storage Configuration
# For ATLAS Rich Context management
# Copy this file to lakebase.yaml and fill in your values

lakebase:
  host: atlas-mariadb
  port: 3306
  user: atlas
  password: ""        # Set via EMBEDDING_DB_PASSWORD or fill in directly
  database: atlas
  max_open_conns: 20
  max_idle_conns: 10
  conn_max_lifetime: 300s

embedding:
  enabled: true
  # Embedding API config is now read from llm_config.json "_embedding" section.
  # You can still override via environment variables: EMBEDDING_API_KEY, EMBEDDING_BASE_URL, EMBEDDING_MODEL
  # Or fill in here if you prefer a separate config:
  # api_key: ""
  # base_url: ""
  # model: ""
  dimension: 1536     # Must match your embedding model's output dimension
  batch_size: 100
  multimodal: false   # Set true if using Volcengine multimodal embedding endpoint

vector_search:
  top_k: 10
  min_score: 0.7
  max_distance: 0.3

agent:
  enable_ddl_detection: true
  check_interval: 60
  auto_refresh_context: true
