# ATLAS System Configuration
# Lakebase-Unified Context-aware Intelligence for Data
# Copy this file to system.yaml and fill in your values

server:
  host: "0.0.0.0"
  port: 19001
  mode: "debug"  # debug | release

# LLM configuration - loads from llm_config.json
# Available models: deepseek_v3, deepseek_v3_2, qwen_max, qwen3_max, ali_deepseek_v3_2
llm:
  config_file: "llm_config.json"
  default_model: "qwen3_max"  # Override via LLM_DEFAULT_MODEL env var

# Lake-Base storage (MariaDB with VECTOR + HNSW)
# All demo and production databases are in this single instance
lakebase:
  host: "atlas-mariadb"
  port: 3306
  user: "atlas"
  password: ""        # Set via MARIADB_PASSWORD env var or fill in directly
  database: "atlas"

# Demo databases (all in MariaDB)
# Passwords are read from environment variables by the application.
# For local Docker deployment, the defaults match docker-compose.yml.
databases:
  # Spider TVShow
  - id: "spider_tvshow"
    name: "Spider TVShow"
    type: "mysql"
    host: "atlas-mariadb"
    port: 3306
    user: "root"
    password: ""        # Set via MARIADB_ROOT_PASSWORD
    database: "spider_tvshow"
    description: "TV show & channel queries — inference pipeline demo"

  # Spider Flight
  - id: "spider_flight"
    name: "Spider Flight"
    type: "mysql"
    host: "atlas-mariadb"
    port: 3306
    user: "root"
    password: ""        # Set via MARIADB_ROOT_PASSWORD
    database: "spider_flight"
    description: "Airport & flight queries — multi-table join demo"

  # Spider WTA Tennis
  - id: "spider_wta"
    name: "Spider WTA"
    type: "mysql"
    host: "atlas-mariadb"
    port: 3306
    user: "root"
    password: ""        # Set via MARIADB_ROOT_PASSWORD
    database: "spider_wta"
    description: "WTA tennis rankings & matches — complex schema demo (8 tables)"

  # Evolution Demo
  - id: "atlas_evolution"
    name: "ATLAS Evolution"
    type: "mysql"
    host: "atlas-mariadb"
    port: 3306
    user: "atlas"
    password: ""        # Set via MARIADB_PASSWORD
    database: "atlas_evolution"
    description: "Agent self-maintenance — 5-stage DDL evolution demo"

  # TPC-H Enterprise (517-table large-scale demo)
  - id: "tpch_enterprise"
    name: "TPC-H Enterprise"
    type: "mysql"
    host: "atlas-mariadb"
    port: 3306
    user: "atlas"
    password: ""        # Set via MARIADB_PASSWORD
    database: "tpch_enterprise"
    description: "TPC-H Enterprise — 517-table large-scale enterprise database for two-stage schema linking + forest-based onboarding demo"

react:
  max_iterations: 5
  enable_rich_context: true
